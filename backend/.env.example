# Copy to .env on the server and fill secrets there. Do not commit .env.
APP_ENV=local
API_PREFIX=/api

QWEN_API_KEY=replace-with-qwen-api-key
QWEN_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

DIFY_API_KEY=replace-with-dify-api-key-if-used
DIFY_API_BASE_URL=https://api.dify.ai/v1

MAX_UPLOAD_MB=20

# Leave unset locally to use backend/data/qihe.db. Production should set /var/lib/qihe/qihe.db.
# QIHE_DB_PATH=/var/lib/qihe/qihe.db
# Legacy compatibility only; prefer QIHE_DB_PATH for new deployments.
AUTH_DB_PATH=
JWT_SECRET=replace-with-long-random-jwt-secret
JWT_EXPIRES_MINUTES=10080
